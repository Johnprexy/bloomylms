# ============================================================
# BloomyLMS Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- REQUIRED ---

# Neon PostgreSQL (neon.tech — free forever)
# Get from: neon.tech → Your Project → Connection Details
DATABASE_URL=postgresql://username:password@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-random-32-character-secret-here
NEXTAUTH_URL=http://localhost:3000

# App URL (change to your Vercel URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- PAYMENTS (paystack.com — free account) ---
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OPTIONAL ---

# Email via Resend (resend.com — 100 emails/day free)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@bloomy360.com

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxx

# Stripe for international payments (stripe.com)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
